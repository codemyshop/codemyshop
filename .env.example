# =============================================================================
# CodeMyShop — environment variables template
# Copy this to `.env` and fill the values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — PostgreSQL 17 + pgvector
# -----------------------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_USER=codemyshop
PG_PASSWORD=changeme-strong-32-chars
PG_DB=codemyshop_main
# Tenant schema (default: public)
PG_SCHEMA=public

# -----------------------------------------------------------------------------
# Redis 7 — sessions, cache, rate limit
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Session / auth
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
HUB_SESSION_SECRET=changeme-32-random-bytes-hex-encoded-required-in-prod

# Knock-gate slug (anti brute-force on /hub). Generate random alphanumeric.
HUB_KNOCK_SLUG=changeme-randomslug

# -----------------------------------------------------------------------------
# Public URLs
# -----------------------------------------------------------------------------
NUXT_PUBLIC_SITE_URL=https://example.com
NUXT_PUBLIC_HUB_URL=https://example.com/hub

# -----------------------------------------------------------------------------
# AI providers — set one or several (Centaure picks cheapest-capable)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
# Default model overrides (optional)
# OPENAI_MODEL=gpt-5
# ANTHROPIC_MODEL=claude-opus-4-7
# MISTRAL_MODEL=mistral-large-latest

# -----------------------------------------------------------------------------
# SMTP — transactional emails (orders, password reset, etc.)
# -----------------------------------------------------------------------------
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME="My Shop"
# Optional IMAP for inbox sync
IMAP_HOST=ssl0.ovh.net
IMAP_PORT=993
IMAP_PASSWORD=

# Preprod-only: redirect ALL outgoing emails to a single address (testing)
# Comment out in production!
# EMAIL_OVERRIDE_TO=dev@example.com

# -----------------------------------------------------------------------------
# Payment — SystemPay (CB) and/or Stripe
# -----------------------------------------------------------------------------
# SystemPay (legacy French CB). Configure via /hub/admin/payments.
SYSTEMPAY_SHOP_ID=
SYSTEMPAY_CERT_TEST=
SYSTEMPAY_CERT_PROD=
SYSTEMPAY_MODE=TEST  # TEST | PROD

# Stripe (recommended for international)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Storage — local filesystem or S3-compatible
# -----------------------------------------------------------------------------
STORAGE_DRIVER=local  # local | s3
STORAGE_LOCAL_PATH=./storage

# If S3 (Scaleway, AWS, MinIO)
# S3_ENDPOINT=https://s3.fr-par.scw.cloud
# S3_REGION=fr-par
# S3_BUCKET=codemyshop-assets
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# -----------------------------------------------------------------------------
# Backup — daily PG dump to S3-compatible bucket
# -----------------------------------------------------------------------------
BACKUP_ENABLED=false
BACKUP_S3_ENDPOINT=https://s3.fr-par.scw.cloud
BACKUP_S3_REGION=fr-par
BACKUP_S3_BUCKET=codemyshop-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# -----------------------------------------------------------------------------
# Bank sync — Powens (optional, for French AE/EI accounting)
# -----------------------------------------------------------------------------
POWENS_DOMAIN=
POWENS_CLIENT_ID=
POWENS_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Analytics — Matomo self-hosted (optional)
# -----------------------------------------------------------------------------
MATOMO_URL=
MATOMO_SITE_ID=
MATOMO_TOKEN=

# -----------------------------------------------------------------------------
# Search Console (optional, for SEO module)
# -----------------------------------------------------------------------------
GSC_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
NODE_ENV=development  # development | production
LOG_LEVEL=info        # debug | info | warn | error
TZ=Europe/Paris
